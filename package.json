{
  "name": "web-demo-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run wasm:build && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "npm run wasm:build && vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "wasm:build": "node scripts/build-wasm.mjs",
    "paper:sync": "node scripts/sync-paper.mjs",
    "lint": "echo 'lint via tsc+vitest (see docs/allowed-console-warnings.md)'",
    "format:check": "echo 'format:check via tsc+vitest (see docs/allowed-console-warnings.md)'"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "idb-keyval": "^6.2.2",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
